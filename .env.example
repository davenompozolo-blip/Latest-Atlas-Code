# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Market Data — Alpha Vantage (optional)
# Free key at alphavantage.co — only needed for fallback/fundamentals
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Alpaca
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_PAPER="true"

# FRED
FRED_API_KEY=your-fred-api-key

# Status Terminal — /status page (server-side only, never expose to client)
# Vercel: create at vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-api-token
# Optional: your Vercel team slug/ID (leave blank for personal account)
VERCEL_TEAM_ID=
# Recommended: scope deployments to this project only (avoids showing other projects in a team)
# Use either the numeric project ID from Vercel dashboard or the project slug name
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=latest-atlas-code

# GitHub: create at github.com/settings/tokens with read:repo scope
# Optional but raises rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=your-github-personal-access-token
# Override if repo owner/name changes
GITHUB_OWNER=davenompozolo-blip
GITHUB_REPO=Latest-Atlas-Code
