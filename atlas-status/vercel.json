{
  "framework": null,
  "installCommand": "echo 'skip install'",
  "outputDirectory": "public",
  "buildCommand": "node inject-env.js",
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "DENY" }
      ]
    }
  ]
}
