{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/claude-analyse.js":  { "maxDuration": 60 },
    "api/claude-sector.js":   { "maxDuration": 60 },
    "api/ledger-snapshot.js": { "maxDuration": 60 },
    "api/ledger-export.js":   { "maxDuration": 30 },
    "api/sync-valuations.js": { "maxDuration": 300 },
    "api/options-snapshot.js": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/ledger-snapshot", "schedule": "30 22 * * 1-5" },
    { "path": "/api/sync-valuations", "schedule": "0 6 * * 1" },
    { "path": "/api/options-snapshot", "schedule": "0 23 * * 1-5" }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
